{
  "name": "preupload-image",
  "version": "1.0.4",
  "description": "Lightweight browser-side image processing before upload — compress, convert to WebP, and resize using Canvas API. No server needed.",
  "main": "dist/index.cjs.js",
  "module": "dist/index.esm.js",
  "browser": "dist/index.umd.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs.js",
      "browser": "./dist/index.umd.js"
    }
  },
  "scripts": {
    "build": "rollup -c rollup.config.js",
    "dev": "rollup -c rollup.config.js --watch",
    "test": "node --experimental-vm-modules node_modules/.bin/jest"
  },
  "keywords": [
    "image",
    "compress",
    "resize",
    "webp",
    "canvas",
    "upload",
    "preupload",
    "browser",
    "client-side",
    "image-processing",
    "file-upload",
    "image-compress",
    "image-resize",
    "image-convert"
  ],
  "author": "BulkPicTools <support@bulkpictools.com> (https://bulkpictools.com)",
  "homepage": "https://bulkpictools.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/kbmjj123/preupload-image"
  },
  "bugs": {
    "url": "https://github.com/kbmjj123/preupload-image/issues"
  },
  "license": "MIT",
  "devDependencies": {
    "rollup": "^4.0.0",
    "@rollup/plugin-terser": "^0.4.4",
    "rollup-plugin-dts": "^6.1.0"
  }
}
